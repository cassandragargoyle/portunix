{
  "apiVersion": "v1",
  "kind": "Package",
  "metadata": {
    "name": "minio",
    "displayName": "MinIO Server",
    "description": "S3-compatible object storage server - community edition is source-only, requires Go to build",
    "category": "infrastructure/storage",
    "homepage": "https://min.io/",
    "documentation": "https://docs.min.io/",
    "license": "AGPL-3.0",
    "maintainer": "MinIO Inc."
  },
  "spec": {
    "hasVariants": true,
    "platforms": {
      "linux": {
        "type": "script",
        "variants": {
          "default": {
            "version": "latest",
            "description": "Build from source via go install (recommended)",
            "installScript": "go install github.com/minio/minio@latest",
            "postInstall": [
              "echo 'MinIO installed to $GOPATH/bin/minio (ensure $GOPATH/bin is in PATH)'"
            ]
          },
          "source": {
            "version": "latest",
            "description": "Clone repository and build manually",
            "installScript": "git clone https://github.com/minio/minio.git /tmp/minio-build && cd /tmp/minio-build && go build -o /usr/local/bin/minio . && rm -rf /tmp/minio-build",
            "postInstall": [
              "chmod +x /usr/local/bin/minio"
            ]
          },
          "container": {
            "type": "container",
            "version": "latest",
            "description": "MinIO S3-compatible object storage as container service",
            "container": {
              "image": "quay.io/minio/minio",
              "tag": "latest",
              "name": "portunix-minio",
              "command": ["server", "/data", "--console-address", ":9001"],
              "ports": ["9000:9000", "9001:9001"],
              "environment": {
                "MINIO_ROOT_USER": "minioadmin",
                "MINIO_ROOT_PASSWORD": "minioadmin"
              },
              "volumes": ["minio-data:/data"],
              "detach": true,
              "healthCheck": {
                "endpoint": "http://localhost:9000/minio/health/live",
                "timeout": 60,
                "interval": 5,
                "retries": 12
              }
            }
          }
        },
        "verification": {
          "command": "minio --version",
          "expectedExitCode": 0
        },
        "environment": {
          "PATH_APPEND": "$HOME/go/bin"
        }
      },
      "darwin": {
        "type": "script",
        "variants": {
          "default": {
            "version": "latest",
            "description": "Build from source via go install (recommended)",
            "installScript": "go install github.com/minio/minio@latest",
            "postInstall": [
              "echo 'MinIO installed to $GOPATH/bin/minio (ensure $GOPATH/bin is in PATH)'"
            ]
          },
          "source": {
            "version": "latest",
            "description": "Clone repository and build manually",
            "installScript": "git clone https://github.com/minio/minio.git /tmp/minio-build && cd /tmp/minio-build && go build -o /usr/local/bin/minio . && rm -rf /tmp/minio-build",
            "postInstall": [
              "chmod +x /usr/local/bin/minio"
            ]
          },
          "container": {
            "type": "container",
            "version": "latest",
            "description": "MinIO S3-compatible object storage as container service",
            "container": {
              "image": "quay.io/minio/minio",
              "tag": "latest",
              "name": "portunix-minio",
              "command": ["server", "/data", "--console-address", ":9001"],
              "ports": ["9000:9000", "9001:9001"],
              "environment": {
                "MINIO_ROOT_USER": "minioadmin",
                "MINIO_ROOT_PASSWORD": "minioadmin"
              },
              "volumes": ["minio-data:/data"],
              "detach": true,
              "healthCheck": {
                "endpoint": "http://localhost:9000/minio/health/live",
                "timeout": 60,
                "interval": 5,
                "retries": 12
              }
            }
          }
        },
        "verification": {
          "command": "minio --version",
          "expectedExitCode": 0
        },
        "environment": {
          "PATH_APPEND": "$HOME/go/bin"
        }
      },
      "windows": {
        "type": "script",
        "variants": {
          "default": {
            "version": "latest",
            "description": "Build from source via go install (recommended)",
            "installScript": "go install github.com/minio/minio@latest",
            "postInstall": [
              "Write-Host 'MinIO installed to %GOPATH%\\bin\\minio.exe (ensure %GOPATH%\\bin is in PATH)'"
            ]
          },
          "source": {
            "version": "latest",
            "description": "Clone repository and build manually",
            "installScript": "git clone https://github.com/minio/minio.git %TEMP%\\minio-build && cd %TEMP%\\minio-build && go build -o %GOPATH%\\bin\\minio.exe . && rd /s /q %TEMP%\\minio-build"
          },
          "container": {
            "type": "container",
            "version": "latest",
            "description": "MinIO S3-compatible object storage as container service (requires Docker Desktop)",
            "container": {
              "image": "quay.io/minio/minio",
              "tag": "latest",
              "name": "portunix-minio",
              "command": ["server", "/data", "--console-address", ":9001"],
              "ports": ["9000:9000", "9001:9001"],
              "environment": {
                "MINIO_ROOT_USER": "minioadmin",
                "MINIO_ROOT_PASSWORD": "minioadmin"
              },
              "volumes": ["minio-data:/data"],
              "detach": true,
              "healthCheck": {
                "endpoint": "http://localhost:9000/minio/health/live",
                "timeout": 60,
                "interval": 5,
                "retries": 12
              }
            }
          }
        },
        "verification": {
          "command": "minio --version",
          "expectedExitCode": 0
        },
        "environment": {
          "PATH_APPEND": "%GOPATH%\\bin"
        }
      }
    },
    "sources": {
      "github": {
        "type": "github",
        "url": "https://github.com/minio/minio",
        "apiEndpoint": "https://api.github.com/repos/minio/minio/releases/latest",
        "pattern": "RELEASE.{date}"
      },
      "container": {
        "type": "docker",
        "url": "https://quay.io/repository/minio/minio",
        "apiEndpoint": "https://quay.io/api/v1/repository/minio/minio/tag/",
        "pattern": "quay.io/minio/minio:{tag}"
      }
    },
    "features": [
      "S3-compatible object storage API",
      "Build from source via go install",
      "Container-based deployment (Docker/Podman)",
      "Web Console on port 9001 (container variant)",
      "Persistent data volume (container variant)",
      "Health check monitoring (container variant)",
      "Default credentials: minioadmin / minioadmin"
    ],
    "aiPrompts": {
      "versionDiscovery": "MinIO community edition is source-only since October 2025. No pre-compiled binaries available. Check https://github.com/minio/minio/releases for latest release tags (date-based: RELEASE.YYYY-MM-DDThh-mm-ssZ). Container images at quay.io/minio/minio.",
      "urlResolution": "Source: go install github.com/minio/minio@latest. Container: quay.io/minio/minio:latest. Manual build: git clone https://github.com/minio/minio.git",
      "updateGuidance": "MinIO uses rolling date-based releases. Default variant uses @latest which always gets the newest version. Container variant uses :latest tag. For pinned versions use go install github.com/minio/minio@RELEASE.YYYY-MM-DDThh-mm-ssZ"
    },
    "dependencies": ["go"],
    "templates": ["go-install", "container-service"]
  }
}
