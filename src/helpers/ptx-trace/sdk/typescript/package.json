  "repository": {
    "type": "git",
    "url": "git+https://github.com/cassandragargoyle/portunix.git"
  },
  "bugs": {
    "url": "https://github.com/cassandragargoyle/portunix/issues"
  },
  "homepage": "https://github.com/cassandragargoyle/portunix/tree/main/sdk/typescript",
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prettier": "^3.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  }
