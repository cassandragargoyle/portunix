{
  // Line length: 150 chars, ignore tables and code blocks
  "MD013": {
    "line_length": 150,
    "tables": false,
    "code_blocks": false
  },
  // Ordered lists use sequential numbering (1, 2, 3)
  "MD029": {
    "style": "ordered"
  },
  // Allow hard tabs inside code blocks (Java/Go code style uses tabs)
  "MD010": {
    "code_blocks": false
  }
}
